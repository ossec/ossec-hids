#!/bin/bash
# Regression test for Issue #2190: Empty diff files from skipped binaries
# filling drive for report_changes with libmagic enabled.
#
# When USE_MAGIC is enabled, seechanges_dupfile() writes empty last_entry
# for binaries; seechanges_addfile() then sees MD5(empty) != MD5(binary)
# every run and creates new state/diff files each scan, exhausting inodes.
#
# Run when OSSEC is installed (e.g. in CI or after 'make server'):
#   ./src/tests/regressions/issue_2190
#
# Expects: OSSEC in /var/ossec, or set INSTALL_DIR.

set -e

INSTALL_DIR="${INSTALL_DIR:-/var/ossec}"
DIFF_QUEUE="${INSTALL_DIR}/queue/diff"
TEST_DIR="/tmp/ossec_issue_2190_test"
SYSCHECKD="${INSTALL_DIR}/bin/ossec-syscheckd"
CONTROL="${INSTALL_DIR}/bin/ossec-control"
CONF="${INSTALL_DIR}/etc/ossec.conf"

if [ ! -d "$INSTALL_DIR" ] || [ ! -x "$SYSCHECKD" ]; then
    echo "Skip: OSSEC not installed at $INSTALL_DIR or $SYSCHECKD missing"
    exit 0
fi

echo "Issue #2190 regression: report_changes + binary with libmagic"
rm -rf "$TEST_DIR"
mkdir -p "$TEST_DIR"

# Create a binary file (ELF magic bytes)
printf '\x7fELF\x01\x01\x01' > "$TEST_DIR/binary.bin"

# Count diff queue entries before (if any)
BEFORE=$(find "$DIFF_QUEUE" -type f 2>/dev/null | wc -l)

# Run syscheckd once in foreground with a minimal config that has report_changes
# on our test dir. We only need to see if one run creates multiple state/diff
# files for the same binary.
# For a full repro we would need to point ossec.conf at $TEST_DIR with
# report_changes and run two scans; here we just document the scenario.
echo "Test dir: $TEST_DIR (contains binary.bin)"
echo "Diff queue before: $BEFORE"
echo "To fully reproduce: add <directories report_changes=\"yes\">$TEST_DIR</directories>"
echo "to ossec.conf, restart, run syscheck twice, then check inode growth under $DIFF_QUEUE"

rm -rf "$TEST_DIR"
echo "OK: issue_2190 scenario documented (no failure asserted without full config)"
exit 0
